PORT=3001
JWT_SECRET=change-this-to-a-long-random-secret
DB_PATH=./data/lemon.db

# Email (SMTP) — leave blank to use console-log mode in dev
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Lemon Note <noreply@example.com>"

# SMS (阿里云短信) — leave blank to use console-log mode in dev
# 申请流程: 阿里云控制台 → 短信服务 → 国内消息 → 签名管理 + 模板管理
# 模板变量固定使用 ${code}，例如: 验证码${code}，5分钟内有效
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
